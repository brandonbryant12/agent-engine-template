# Backend base URL used by auth and API clients
PUBLIC_SERVER_URL=http://localhost:3035

# Backend API path prefix
PUBLIC_SERVER_API_PATH=/api

# Vite dev server URL (used only by apps/web/vite.config.ts)
PUBLIC_WEB_URL=http://localhost:8085

# Optional base path when serving from a sub-path (e.g. /my-app)
PUBLIC_BASE_PATH=/
